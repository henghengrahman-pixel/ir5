<div class="admin-shell">
  <%- include('partials/sidebar') %>

  <main class="admin-main">

    <div class="admin-page-head">
      <div>
        <span class="eyebrow">News CMS</span>

        <h1>
          <%= post ? 'Edit Berita Bola' : 'Tambah Berita Bola' %>
        </h1>

        <p>
          Kelola artikel berita bola dengan visual editor modern seperti Blogger.
        </p>
      </div>
    </div>

    <form
      class="admin-card admin-form-grid"
      method="post"
      enctype="multipart/form-data"
      action="<%= post ? '/admin/posts/' + post.id + '/update' : '/admin/posts' %>"
      id="postForm"
    >

      <!-- ===================================================== -->
      <!-- BASIC -->
      <!-- ===================================================== -->

      <label class="full">
        <span>Judul Berita</span>

        <input
          id="titleInput"
          name="title"
          value="<%= post?.title || '' %>"
          required
          placeholder="Contoh: Barcelona Siapkan Transfer Besar Musim Panas Ini"
        >
      </label>

      <label>
        <span>Slug URL</span>

        <input
          id="slugInput"
          name="slug"
          value="<%= post?.slug || '' %>"
          placeholder="otomatis kalau dikosongkan"
        >
      </label>

      <label>
        <span>Kategori</span>

        <input
          name="category"
          value="<%= post?.category || 'Berita Bola' %>"
          placeholder="Liga Inggris, Liga Indonesia, Transfer"
        >
      </label>

      <label>
        <span>Author</span>

        <input
          name="author"
          value="<%= post?.author || 'Redaksi Bola' %>"
        >
      </label>

      <label>
        <span>Tanggal</span>

        <input
          type="datetime-local"
          name="createdAt"
          value="<%= post?.createdAt ? new Date(post.createdAt).toISOString().slice(0,16) : '' %>"
        >
      </label>

      <label>
        <span>Tags</span>

        <input
          name="tags"
          value="<%= (post?.tags || []).join(', ') %>"
          placeholder="Barcelona, Transfer, Liga Spanyol"
        >
      </label>

      <!-- ===================================================== -->
      <!-- IMAGE -->
      <!-- ===================================================== -->

      <label>
        <span>Thumbnail URL</span>

        <input
          name="thumbnailUrl"
          value="<%= post?.thumbnail || '' %>"
          placeholder="https://..."
        >
      </label>

      <label>
        <span>Upload Thumbnail</span>

        <input
          type="file"
          name="thumbnailFile"
          accept="image/*"
        >
      </label>

      <label>
        <span>Cover URL</span>

        <input
          name="coverUrl"
          value="<%= post?.cover || '' %>"
          placeholder="https://..."
        >
      </label>

      <label>
        <span>Upload Cover</span>

        <input
          type="file"
          name="coverFile"
          accept="image/*"
        >
      </label>

      <!-- ===================================================== -->
      <!-- EXCERPT -->
      <!-- ===================================================== -->

      <label class="full">
        <span>Excerpt / Ringkasan</span>

        <textarea
          name="excerpt"
          rows="4"
          placeholder="Ringkasan singkat untuk card berita"
        ><%= post?.excerpt || '' %></textarea>
      </label>

      <!-- ===================================================== -->
      <!-- TOOLBAR -->
      <!-- ===================================================== -->

      <div class="full">

        <div class="editor-toolbar">

          <button type="button" data-cmd="formatBlock" data-value="h2">
            H2
          </button>

          <button type="button" data-cmd="formatBlock" data-value="h3">
            H3
          </button>

          <button type="button" data-cmd="bold">
            Bold
          </button>

          <button type="button" data-cmd="italic">
            Italic
          </button>

          <button type="button" data-cmd="insertUnorderedList">
            List
          </button>

          <button type="button" data-cmd="blockquote">
            Quote
          </button>

          <button type="button" id="insertLinkBtn">
            Link
          </button>

          <button type="button" id="insertImageBtn">
            Image
          </button>

          <button type="button" id="insertYoutubeBtn">
            YouTube
          </button>

          <button type="button" id="insertTableBtn">
            Table
          </button>

          <button type="button" id="clearFormatBtn">
            Clear
          </button>

        </div>

      </div>

      <!-- ===================================================== -->
      <!-- VISUAL EDITOR -->
      <!-- ===================================================== -->

      <div class="full editor-layout">

        <div class="editor-panel">

          <div class="editor-head">
            <span>Visual Editor</span>

            <div class="editor-info">
              Tulis artikel seperti Blogger / WordPress
            </div>
          </div>

          <div
            id="visualEditor"
            class="visual-editor"
            contenteditable="true"
          ><%- post?.content || '<p>Mulai tulis berita bola di sini...</p>' %></div>

          <textarea
            id="contentEditor"
            name="content"
            hidden
          ><%= post?.content || '' %></textarea>

        </div>

        <!-- ================================================= -->
        <!-- PREVIEW -->
        <!-- ================================================= -->

        <div class="preview-panel">

          <div class="preview-head">
            <h3>Preview Artikel</h3>
          </div>

          <div
            id="livePreview"
            class="live-preview"
          ></div>

        </div>

      </div>

      <!-- ===================================================== -->
      <!-- STATUS -->
      <!-- ===================================================== -->

      <div class="full post-options">

        <label class="checkbox">
          <input
            type="checkbox"
            name="published"
            <%= !post || post.published ? 'checked' : '' %>
          >
          Publish
        </label>

        <label class="checkbox">
          <input
            type="checkbox"
            name="trending"
            <%= post?.trending ? 'checked' : '' %>
          >
          Trending
        </label>

        <label class="checkbox">
          <input
            type="checkbox"
            name="featured"
            <%= post?.featured ? 'checked' : '' %>
          >
          Artikel Pilihan
        </label>

      </div>

      <!-- ===================================================== -->
      <!-- ACTION -->
      <!-- ===================================================== -->

      <div class="admin-actions-row full">

        <button class="admin-btn" type="submit">
          Simpan Berita
        </button>

        <a
          class="admin-btn ghost"
          href="/admin/posts"
        >
          Kembali
        </a>

      </div>

    </form>

  </main>
</div>

<script>

  /* =========================================================
     SLUG AUTO
  ========================================================= */

  const titleInput =
    document.getElementById('titleInput');

  const slugInput =
    document.getElementById('slugInput');

  if(titleInput && slugInput){

    titleInput.addEventListener('input', () => {

      if(slugInput.value.trim()) return;

      slugInput.value = titleInput.value

        .toLowerCase()

        .trim()

        .replace(/[^a-z0-9]+/g,'-')

        .replace(/^-|-$/g,'');

    });

  }

  /* =========================================================
     VISUAL EDITOR
  ========================================================= */

  const editor =
    document.getElementById('visualEditor');

  const textarea =
    document.getElementById('contentEditor');

  const preview =
    document.getElementById('livePreview');

  function syncEditor(){

    textarea.value =
      editor.innerHTML;

    preview.innerHTML =
      editor.innerHTML;

  }

  editor.addEventListener(
    'input',
    syncEditor
  );

  syncEditor();

  /* =========================================================
     TOOLBAR
  ========================================================= */

  document.querySelectorAll('[data-cmd]').forEach(btn => {

    btn.addEventListener('click', () => {

      const cmd =
        btn.dataset.cmd;

      const value =
        btn.dataset.value || null;

      if(cmd === 'blockquote'){

        document.execCommand(
          'formatBlock',
          false,
          'blockquote'
        );

      }else{

        document.execCommand(
          cmd,
          false,
          value
        );

      }

      editor.focus();

      syncEditor();

    });

  });

  /* =========================================================
     LINK
  ========================================================= */

  document.getElementById('insertLinkBtn')
    .addEventListener('click', () => {

      const url =
        prompt('Masukkan URL');

      if(!url) return;

      document.execCommand(
        'createLink',
        false,
        url
      );

      syncEditor();

    });

  /* =========================================================
     IMAGE
  ========================================================= */

  document.getElementById('insertImageBtn')
    .addEventListener('click', () => {

      const url =
        prompt('Masukkan URL gambar');

      if(!url) return;

      document.execCommand(
        'insertHTML',
        false,
        `<p><img src="${url}" alt="Berita Bola"></p>`
      );

      syncEditor();

    });

  /* =========================================================
     YOUTUBE
  ========================================================= */

  document.getElementById('insertYoutubeBtn')
    .addEventListener('click', () => {

      const url =
        prompt('Masukkan link YouTube');

      if(!url) return;

      let videoId = '';

      if(url.includes('watch?v=')){

        videoId =
          url.split('watch?v=')[1]
            .split('&')[0];

      }else if(url.includes('youtu.be/')){

        videoId =
          url.split('youtu.be/')[1]
            .split('?')[0];

      }

      if(!videoId) return;

      document.execCommand(
        'insertHTML',
        false,
        `
        <iframe
          src="https://www.youtube.com/embed/${videoId}"
          title="YouTube video"
          allowfullscreen
        ></iframe>
        `
      );

      syncEditor();

    });

  /* =========================================================
     TABLE
  ========================================================= */

  document.getElementById('insertTableBtn')
    .addEventListener('click', () => {

      document.execCommand(
        'insertHTML',
        false,
        `
        <table>
          <thead>
            <tr>
              <th>Data</th>
              <th>Keterangan</th>
            </tr>
          </thead>

          <tbody>
            <tr>
              <td>Tim</td>
              <td>Informasi</td>
            </tr>
          </tbody>
        </table>
        `
      );

      syncEditor();

    });

  /* =========================================================
     CLEAR FORMAT
  ========================================================= */

  document.getElementById('clearFormatBtn')
    .addEventListener('click', () => {

      document.execCommand(
        'removeFormat',
        false,
        null
      );

      syncEditor();

    });

  /* =========================================================
     SUBMIT
  ========================================================= */

  document.getElementById('postForm')
    .addEventListener('submit', () => {

      textarea.value =
        editor.innerHTML;

    });

</script>
