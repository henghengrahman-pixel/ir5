<div class="admin-shell">
  <%- include('partials/sidebar') %>
  <main class="admin-main">
    <h1>Site Settings</h1>
    <div class="admin-card">
      <form class="admin-form-grid" method="post" action="/admin/settings">
        <label>Nama Website<input name="siteName" value="<%= settings.siteName || '' %>" required /></label>
        <label>Warna Utama<input name="primaryColor" value="<%= settings.primaryColor || '#d90018' %>" placeholder="#d90018" /></label>
        <label>Login URL<input name="loginUrl" value="<%= settings.loginUrl || '' %>" /></label>
        <label>Register URL<input name="registerUrl" value="<%= settings.registerUrl || '' %>" /></label>
        <label>Logo URL<input name="logoUrl" value="<%= settings.logoUrl || '' %>" /></label>
        <label>Favicon URL<input name="faviconUrl" value="<%= settings.faviconUrl || settings.logoUrl || '' %>" /></label>
        <label>Background Desktop<input name="backgroundDesktop" value="<%= settings.backgroundDesktop || '' %>" /></label>
        <label>Background Mobile<input name="backgroundMobile" value="<%= settings.backgroundMobile || '' %>" /></label>
        <label>Telegram<input name="telegramUrl" value="<%= settings.telegramUrl || '' %>" /></label>
        <label>WhatsApp<input name="whatsappUrl" value="<%= settings.whatsappUrl || '' %>" /></label>
        <label>Livechat<input name="livechatUrl" value="<%= settings.livechatUrl || '' %>" /></label>
        <label>Facebook<input name="facebookUrl" value="<%= settings.facebookUrl || '' %>" /></label>
        <label>Instagram<input name="instagramUrl" value="<%= settings.instagramUrl || '' %>" /></label>
        <label>Footer Text<input name="footerText" value="<%= settings.footerText || '' %>" /></label>
        <label class="full">Running Text<textarea name="runningText" rows="3"><%= settings.runningText || '' %></textarea></label>
        <label>Meta Title<input name="metaTitle" value="<%= settings.metaTitle || '' %>" /></label>
        <label>Meta Keywords<input name="metaKeywords" value="<%= settings.metaKeywords || '' %>" /></label>
        <label class="full">Meta Description<textarea name="metaDescription" rows="4"><%= settings.metaDescription || '' %></textarea></label>
        <button class="admin-btn" type="submit">Simpan Settings</button>
      </form>
    </div>
  </main>
</div>
