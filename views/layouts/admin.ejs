<!doctype html>
<html lang="id">
<head>

  <meta charset="utf-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1"
  />

  <title>
    <%= pageTitle || 'Admin Portal Bola' %>
  </title>

  <!-- ===================================================== -->
  <!-- FONT -->
  <!-- ===================================================== -->

  <link
    rel="preconnect"
    href="https://fonts.googleapis.com"
  >

  <link
    rel="preconnect"
    href="https://fonts.gstatic.com"
    crossorigin
  >

  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
    rel="stylesheet"
  >

  <!-- ===================================================== -->
  <!-- ADMIN CSS -->
  <!-- ===================================================== -->

  <link
    rel="stylesheet"
    href="/assets/css/admin.css"
  />

  <!-- ===================================================== -->
  <!-- TINYMCE -->
  <!-- ===================================================== -->

  <script
    src="https://cdn.tiny.cloud/1/no-api-key/tinymce/6/tinymce.min.js"
    referrerpolicy="origin"
  ></script>

</head>

<body class="admin-body">

  <%- body %>

  <!-- ===================================================== -->
  <!-- BLOGGER STYLE EDITOR -->
  <!-- ===================================================== -->

  <script>

    document.addEventListener('DOMContentLoaded', () => {

      const editor =
        document.querySelector('#contentEditor');

      if(!editor) return;

      tinymce.init({

        selector:'#contentEditor',

        height:720,

        menubar:true,

        branding:false,

        promotion:false,

        resize:true,

        statusbar:true,

        browser_spellcheck:true,

        object_resizing:true,

        convert_urls:false,

        relative_urls:false,

        remove_script_host:false,

        paste_data_images:true,

        skin:'oxide-dark',

        content_css:'dark',

        toolbar_sticky:true,

        toolbar_mode:'sliding',

        plugins:[

          'advlist',
          'anchor',
          'autolink',
          'autosave',
          'charmap',
          'code',
          'codesample',
          'directionality',
          'emoticons',
          'fullscreen',
          'help',
          'image',
          'insertdatetime',
          'link',
          'lists',
          'media',
          'preview',
          'searchreplace',
          'table',
          'visualblocks',
          'visualchars',
          'wordcount'

        ],

        toolbar:[

          'undo redo | blocks fontfamily fontsize |',
          'bold italic underline strikethrough |',
          'forecolor backcolor |',
          'alignleft aligncenter alignright alignjustify |',
          'bullist numlist outdent indent |',
          'link image media table |',
          'blockquote codesample |',
          'removeformat |',
          'visualblocks code preview fullscreen'

        ],

        font_family_formats:
          'Inter=Inter,sans-serif;' +
          'Arial=arial,helvetica,sans-serif;' +
          'Verdana=verdana,geneva,sans-serif;' +
          'Tahoma=tahoma,arial,helvetica,sans-serif;' +
          'Georgia=georgia,palatino,serif;' +
          'Times New Roman=times new roman,times,serif;' +
          'Courier New=courier new,courier,monospace;',

        content_style:`

          body{
            background:#ffffff;
            color:#111827;
            font-family:Inter,sans-serif;
            font-size:17px;
            line-height:1.95;
            max-width:860px;
            margin:40px auto;
            padding:0 24px;
          }

          p{
            margin:0 0 24px;
          }

          h1,h2,h3,h4{
            line-height:1.3;
            margin:38px 0 18px;
            color:#111827;
            font-weight:800;
          }

          h1{
            font-size:42px;
          }

          h2{
            font-size:34px;
          }

          h3{
            font-size:28px;
          }

          h4{
            font-size:24px;
          }

          ul,ol{
            margin:0 0 24px 24px;
            padding:0;
          }

          li{
            margin-bottom:10px;
          }

          img{
            max-width:100%;
            height:auto;
            border-radius:16px;
            display:block;
            margin:28px auto;
          }

          iframe{
            width:100%;
            aspect-ratio:16/9;
            border:0;
            border-radius:18px;
            margin:28px 0;
          }

          table{
            width:100%;
            border-collapse:collapse;
            margin:28px 0;
          }

          table th,
          table td{
            border:1px solid #d1d5db;
            padding:14px;
            text-align:left;
          }

          blockquote{
            margin:30px 0;
            padding:18px 22px;
            border-left:4px solid #f59e0b;
            background:#f3f4f6;
            border-radius:14px;
          }

        `,

        setup(editor){

          editor.on('change', () => {
            editor.save();
          });

          editor.on('keyup', () => {
            editor.save();
          });

        }

      });

    });

  </script>

</body>
</html>
