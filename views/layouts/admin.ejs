<!doctype html>
<html lang="id">
<head>

  <meta charset="utf-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1"
  />

  <title>
    <%= pageTitle || 'Admin Portal Bola' %>
  </title>

  <!-- ===================================================== -->
  <!-- FONT -->
  <!-- ===================================================== -->

  <link
    rel="preconnect"
    href="https://fonts.googleapis.com"
  >

  <link
    rel="preconnect"
    href="https://fonts.gstatic.com"
    crossorigin
  >

  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
    rel="stylesheet"
  >

  <!-- ===================================================== -->
  <!-- ADMIN CSS -->
  <!-- ===================================================== -->

  <link
    rel="stylesheet"
    href="/assets/css/admin.css"
  />

  <!-- ===================================================== -->
  <!-- CKEDITOR -->
  <!-- ===================================================== -->

  <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>

</head>

<body class="admin-body">

  <%- body %>

  <!-- ===================================================== -->
  <!-- CKEDITOR INIT -->
  <!-- ===================================================== -->

  <script>

    document.addEventListener('DOMContentLoaded', () => {

      const editorEl =
        document.querySelector('#contentEditor');

      if(!editorEl) return;

      ClassicEditor

        .create(editorEl, {

          placeholder:
            'Mulai tulis berita bola di sini...',

          toolbar: [

            'heading',

            '|',

            'bold',
            'italic',
            'underline',

            '|',

            'link',

            'bulletedList',
            'numberedList',

            '|',

            'blockQuote',

            'insertTable',

            '|',

            'undo',
            'redo'

          ],

          table:{
            contentToolbar:[
              'tableColumn',
              'tableRow',
              'mergeTableCells'
            ]
          }

        })

        .then(editor => {

          window.editor = editor;

          editor.model.document.on(
            'change:data',
            () => {

              const html =
                editor.getData();

              const preview =
                document.getElementById('livePreview');

              if(preview){
                preview.innerHTML = html;
              }

            }
          );

        })

        .catch(error => {

          console.error(error);

        });

    });

  </script>

</body>
</html>
