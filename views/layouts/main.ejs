<!doctype html>
<html lang="id">
<head>
  <%- include('../partials/head') %>
  <style>
    :root{--primary:<%= settings.primaryColor || '#f5c542' %>;--accent:<%= settings.accentColor || '#ffb300' %>;--portal-bg:url('<%= settings.backgroundDesktop || '' %>')}
    @media(max-width:768px){:root{--portal-bg:url('<%= settings.backgroundMobile || settings.backgroundDesktop || '' %>')}}
  </style>
</head>
<body class="<%= typeof bodyClass !== 'undefined' ? bodyClass : '' %>">
  <%- body %>
  <%- include('../partials/scripts') %>
</body>
</html>
