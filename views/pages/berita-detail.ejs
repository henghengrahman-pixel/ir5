<%- include('../partials/topbar') %>
<%- include('../partials/ticker') %>
<%- include('../partials/slider') %>
<%- include('../partials/auth-buttons') %>

<%
function normalizeArticle(content = '') {
  if (!content) return '';

  let html = String(content);

  html = html.replace(/\r\n/g, '\n');

  if (
    !/<(p|h1|h2|h3|ul|ol|li|table|img|iframe|blockquote|div)/i.test(html)
  ) {
    html = html
      .split(/\n{2,}/)
      .map(p => {
        const text = p.trim();
        if (!text) return '';
        return `<p>${text.replace(/\n/g, '<br>')}</p>`;
      })
      .join('');
  }

  html = html.replace(
    /<iframe([^>]*)>/gi,
    '<div class="responsive-embed"><iframe$1>'
  );

  html = html.replace(/<\/iframe>/gi, '</iframe></div>');

  html = html.replace(
    /<table/gi,
    '<div class="table-wrap"><table'
  );

  html = html.replace(
    /<\/table>/gi,
    '</table></div>'
  );

  return html;
}
%>

<main class="container blog-wrap single-layout">
  <div class="blog-layout">

    <article class="single-post">

      <a class="badge" href="/category/<%= categorySlug(post.category) %>">
        <%= post.category || 'Berita Bola' %>
      </a>

      <h1 class="single-title">
        <%= post.title %>
      </h1>

      <div class="single-meta">
        <span><%= fmtDate(post.createdAt) %></span>
        <span>•</span>
        <span><%= post.author || 'Redaksi Bola' %></span>

        <% (post.tags || []).forEach(function(tag){ %>
          <span>• #<%= tag %></span>
        <% }) %>
      </div>

      <% const heroImage = post.cover || post.thumbnail; %>

      <% if (heroImage) { %>
        <div class="single-cover-wrap">
          <img
            class="single-cover"
            src="<%= heroImage %>"
            alt="<%= post.title %>"
            loading="lazy"
            onerror="this.style.display='none'"
          >
        </div>
      <% } %>

      <div class="share-row">
        <a
          href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent(shareUrl) %>"
          target="_blank"
          rel="noopener"
        >
          Facebook
        </a>

        <a
          href="https://twitter.com/intent/tweet?url=<%= encodeURIComponent(shareUrl) %>&text=<%= encodeURIComponent(post.title) %>"
          target="_blank"
          rel="noopener"
        >
          X
        </a>

        <a
          href="https://api.whatsapp.com/send?text=<%= encodeURIComponent(post.title + ' ' + shareUrl) %>"
          target="_blank"
          rel="noopener"
        >
          WhatsApp
        </a>
      </div>

      <div class="article-content">
        <%- normalizeArticle(post.content) %>
      </div>

      <% if (related && related.length) { %>
        <section class="related">
          <div class="section-head">
            <h2>Related Article</h2>
          </div>

          <div class="related-grid">
            <% related.forEach(function(item){ %>

              <a class="related-card" href="<%= articleUrl(item) %>">

                <% if (item.thumbnail) { %>
                  <img
                    src="<%= item.thumbnail %>"
                    alt="<%= item.title %>"
                    loading="lazy"
                    onerror="this.style.display='none'"
                  >
                <% } %>

                <div class="related-content">
                  <span class="related-category">
                    <%= item.category || 'Berita Bola' %>
                  </span>

                  <h3><%= item.title %></h3>

                  <span class="related-date">
                    <%= fmtDate(item.createdAt) %>
                  </span>
                </div>

              </a>

            <% }) %>
          </div>
        </section>
      <% } %>

    </article>

    <aside class="blog-sidebar">

      <div class="widget search-widget">
        <div class="widget-title">
          Cari Berita
        </div>

        <form action="/search" method="get">
          <input
            type="text"
            name="q"
            placeholder="Cari berita bola..."
          >

          <button type="submit">
            Cari
          </button>
        </form>
      </div>

      <div class="widget">
        <div class="widget-title">
          Artikel Terbaru
        </div>

        <% latest.forEach(function(item){ %>

          <a
            class="side-link"
            href="<%= articleUrl(item) %>"
          >
            <% if (item.thumbnail) { %>
              <img
                src="<%= item.thumbnail %>"
                alt="<%= item.title %>"
                loading="lazy"
                onerror="this.style.display='none'"
              >
            <% } %>

            <div>
              <strong><%= item.title %></strong>
              <span><%= fmtDate(item.createdAt) %></span>
            </div>
          </a>

        <% }) %>
      </div>

      <% ads
        .filter(function(ad){
          return ad.position === 'sidebar' || !ad.position;
        })
        .slice(0,3)
        .forEach(function(ad){ %>

        <a
          class="ad-box"
          href="<%= ad.link || '#' %>"
          target="_blank"
          rel="noopener"
        >
          <img
            src="<%= ad.image %>"
            alt="<%= ad.title || 'Banner' %>"
            loading="lazy"
            onerror="this.style.display='none'"
          >
        </a>

      <% }) %>

    </aside>

  </div>
</main>

<%- include('../partials/footer') %>
<%- include('../partials/quick-menu') %>
