<%- include('../partials/topbar') %><%- include('../partials/ticker') %>
<section class="page-title"><div class="container"><span class="eyebrow">Berita Bola</span><h1>Berita Bola Terbaru</h1><p>Update artikel, hot news, big match, transfer, jadwal, dan analisa liga besar.</p><form class="searchbar" action="/berita"><input name="q" value="<%= q || '' %>" placeholder="Cari berita bola..."><button class="btn primary">Cari</button></form></div></section>
<main class="section"><div class="container cards-grid"><% if(posts.length){ posts.forEach(function(post){ %><a class="article-card" href="<%= postUrl(post) %>"><div class="thumb"><% if(post.thumbnail){ %><img src="<%= post.thumbnail %>" alt="<%= post.title %>"><% } else { %>BERITA BOLA<% } %></div><div class="card-body"><div class="meta"><span><%= post.category %></span><span><%= fmtDate(post.createdAt) %></span><span><%= post.author %></span></div><h3><%= post.title %></h3><p><%= post.excerpt %></p></div></a><% }) } else { %><div class="empty">Artikel belum ditemukan.</div><% } %></div></main>
<%- include('../partials/footer') %><%- include('../partials/quick-menu') %>
