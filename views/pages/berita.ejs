<%- include('../partials/topbar') %>
<%- include('../partials/ticker') %>
<%- include('../partials/slider') %>
<%- include('../partials/auth-buttons') %>

<section class="news-hero">
  <div class="container">

    <span class="news-kicker">
      PORTAL BERITA BOLA
    </span>

    <h1>
      Berita Bola Terbaru
    </h1>

    <p>
      Update sepak bola terbaru, transfer pemain, big match,
      jadwal liga besar, hasil pertandingan, dan artikel pilihan
      dengan tampilan modern nyaman dibaca setiap hari.
    </p>

  </div>
</section>

<main class="container blog-wrap">

  <div class="blog-layout">

    <!-- ===================================================== -->
    <!-- CONTENT -->
    <!-- ===================================================== -->

    <section class="post-list">

      <% if (!posts.length) { %>

        <article class="news-empty">

          <h3>
            Belum ada berita
          </h3>

          <p>
            Artikel berita bola belum tersedia saat ini.
          </p>

        </article>

      <% } %>

      <% posts.forEach(function(post){ %>

        <article class="news-card">

          <a
            class="news-thumb"
            href="<%= articleUrl(post) %>"
          >

            <img
              src="<%= post.thumbnail || post.cover || settings.logoUrl || '/assets/img/default.jpg' %>"
              alt="<%= post.title %>"
              loading="lazy"

              onerror="
                this.onerror=null;
                this.src='<%= settings.logoUrl || '/assets/img/default.jpg' %>';
              "
            >

          </a>

          <div class="news-body">

            <div class="news-top-meta">

              <a
                class="badge"
                href="/category/<%= categorySlug(post.category) %>"
              >
                <%= post.category || 'Berita Bola' %>
              </a>

              <% if(post.trending){ %>
                <span class="mini-hot">
                  Trending
                </span>
              <% } %>

            </div>

            <h2>
              <a href="<%= articleUrl(post) %>">
                <%= post.title %>
              </a>
            </h2>

            <div class="post-meta">

              <span>
                <%= fmtDate(post.createdAt) %>
              </span>

              <span>•</span>

              <span>
                <%= post.author || 'Redaksi Bola' %>
              </span>

              <% if(post.tags?.length){ %>

                <span>•</span>

                <span>
                  #<%= post.tags[0] %>
                </span>

              <% } %>

            </div>

            <p>
              <%= post.excerpt || 'Baca update lengkap berita bola terbaru, analisa pertandingan, transfer pemain, dan informasi sepak bola pilihan hari ini.' %>
            </p>

            <div class="news-actions">

              <a
                class="read-more"
                href="<%= articleUrl(post) %>"
              >
                Baca Selengkapnya
              </a>

            </div>

          </div>

        </article>

      <% }) %>

      <!-- ===================================================== -->
      <!-- PAGINATION -->
      <!-- ===================================================== -->

      <% if (totalPages > 1) { %>

        <nav class="pagination">

          <% if(currentPage > 1){ %>

            <a href="/berita?page=<%= currentPage - 1 %>">
              ←
            </a>

          <% } %>

          <% for (let i = 1; i <= totalPages; i++) { %>

            <a
              class="<%= i === currentPage ? 'on' : '' %>"
              href="/berita?page=<%= i %>"
            >
              <%= i %>
            </a>

          <% } %>

          <% if(currentPage < totalPages){ %>

            <a href="/berita?page=<%= currentPage + 1 %>">
              →
            </a>

          <% } %>

        </nav>

      <% } %>

    </section>

    <!-- ===================================================== -->
    <!-- SIDEBAR -->
    <!-- ===================================================== -->

    <aside class="blog-sidebar">

      <!-- SEARCH -->

      <div class="widget search-widget">

        <div class="widget-title">
          Cari Berita
        </div>

        <form action="/search" method="get">

          <input
            name="q"
            placeholder="Cari klub, liga, pemain..."
          >

          <button type="submit">
            Cari
          </button>

        </form>

      </div>

      <!-- TRENDING -->

      <div class="widget">

        <div class="widget-title">
          Trending News
        </div>

        <% (trending || allPosts.slice(0,6)).forEach(function(item){ %>

          <a
            class="side-link"
            href="<%= articleUrl(item) %>"
          >

            <% if(item.thumbnail || item.cover){ %>

              <img
                src="<%= item.thumbnail || item.cover %>"
                alt="<%= item.title %>"
                loading="lazy"

                onerror="
                  this.onerror=null;
                  this.src='<%= settings.logoUrl || '/assets/img/default.jpg' %>';
                "
              >

            <% } %>

            <div>

              <strong>
                <%= item.title %>
              </strong>

              <span>
                <%= fmtDate(item.createdAt) %>
              </span>

            </div>

          </a>

        <% }) %>

      </div>

      <!-- KATEGORI -->

      <div class="widget">

        <div class="widget-title">
          Kategori Populer
        </div>

        <div class="category-list">

          <% [...new Set(allPosts.map(p => p.category).filter(Boolean))]
            .slice(0,8)
            .forEach(function(cat){ %>

            <a
              href="/category/<%= categorySlug(cat) %>"
              class="category-pill"
            >
              <%= cat %>
            </a>

          <% }) %>

        </div>

      </div>

      <!-- ADS -->

      <% ads
        .filter(function(ad){
          return ad.position === 'sidebar' || !ad.position;
        })
        .slice(0,3)
        .forEach(function(ad){ %>

        <a
          class="ad-box"
          href="<%= ad.link || '#' %>"
          target="_blank"
          rel="noopener"
        >

          <img
            src="<%= ad.image %>"
            alt="<%= ad.title || 'Banner' %>"
            loading="lazy"

            onerror="
              this.style.display='none';
            "
          >

        </a>

      <% }) %>

    </aside>

  </div>

</main>

<%- include('../partials/footer') %>
<%- include('../partials/quick-menu') %>
