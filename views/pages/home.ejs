<%- include('../partials/topbar') %>
<%- include('../partials/ticker') %>
<section class="hero-portal">
  <div class="container portal-grid">
    <article class="hero-card">
      <% if (featured && (featured.cover || featured.thumbnail)) { %><img src="<%= featured.cover || featured.thumbnail %>" alt="<%= featured.title %>"><% } %>
      <div class="hero-content">
        <span class="eyebrow">Portal Bola Premium</span>
        <h1><%= featured?.title || 'Berita Bola dan Prediksi Bola Hari Ini' %></h1>
        <p><%= featured?.excerpt || settings.metaDescription || 'Update berita bola, big match, live score, dan prediksi dari liga besar.' %></p>
        <a class="btn primary" href="<%= featured ? postUrl(featured) : '/berita' %>">Baca Selengkapnya</a>
      </div>
    </article>
    <aside class="side-stack">
      <div class="soft-card card-body"><span class="eyebrow">Big Match</span><h3>Prediksi Bola Hari Ini</h3><p>Fokus Liga Indonesia, Premier League, Champions League, Serie A, La Liga, Bundesliga, Ligue 1, dan Europa League.</p><a class="btn" href="/prediksi-parlay">Lihat Prediksi</a></div>
      <div class="soft-card card-body"><span class="eyebrow">Live</span><h3>Live Score</h3><p>Skor langsung, upcoming, finished, filter liga, dan statistik singkat.</p><a class="btn" href="/live">Buka Live Score</a></div>
    </aside>
  </div>
</section>
<%- include('../partials/slider') %>
<section class="section"><div class="container"><div class="section-head"><div><h2>Prediksi Bola Hari Ini</h2><p>Match pilihan dengan format clean: skor, 1X2, over/under, confidence, dan form singkat.</p></div><a class="btn" href="/prediksi-parlay">Semua Prediksi</a></div><div class="prediction-list">
<% if ((homePredictions||[]).length) { homePredictions.slice(0,6).forEach(function(m){ %>
  <a class="match-card" href="<%= m.url %>"><div class="match-top"><span><%= m.league %></span><span><%= m.kickoffWib %></span></div><div class="teams"><div class="team"><% if(m.homeLogo){ %><img class="team-logo" src="<%= m.homeLogo %>" onerror="this.src='/assets/img/default-team.png'"><% } else { %><span class="team-logo"></span><% } %><b><%= m.homeName %></b></div><div class="vs">VS</div><div class="team away"><b><%= m.awayName %></b><% if(m.awayLogo){ %><img class="team-logo" src="<%= m.awayLogo %>" onerror="this.src='/assets/img/default-team.png'"><% } else { %><span class="team-logo"></span><% } %></div></div><div class="pick-row"><div class="pill"><small>Prediksi</small><b><%= m.prediction %></b></div><div class="pill"><small>Skor</small><b><%= m.predictedScore %></b></div><div class="pill"><small>O/U</small><b><%= m.overUnder %></b></div><div class="pill"><small>Confidence</small><b><%= m.confidence %>%</b><div class="progress"><i style="width:<%= m.confidence %>%"></i></div></div></div></a>
<% }) } else { %><div class="empty">Belum ada data prediksi. Jalankan auto parlay atau tambah prediksi dari admin.</div><% } %>
</div></div></section>
<section class="section"><div class="container"><div class="section-head"><div><h2>Berita Terbaru</h2><p>Artikel bola terbaru dengan kategori, tag, author, dan halaman SEO.</p></div><a class="btn" href="/berita">Semua Berita</a></div><div class="cards-grid"><% (latestArticles||[]).forEach(function(post){ %><a class="article-card" href="<%= postUrl(post) %>"><div class="thumb"><% if(post.thumbnail){ %><img src="<%= post.thumbnail %>" alt="<%= post.title %>"><% } else { %>BERITA BOLA<% } %></div><div class="card-body"><div class="meta"><span><%= post.category %></span><span><%= fmtDate(post.createdAt) %></span></div><h3><%= post.title %></h3><p><%= post.excerpt %></p></div></a><% }) %></div></div></section>
<section class="section"><div class="container"><div class="section-head"><div><h2>Trending Match & Hot News</h2><p>Konten pilihan yang sedang disorot.</p></div></div><div class="cards-grid"><% (trending.length?trending:hotNews).slice(0,6).forEach(function(post){ %><a class="article-card" href="<%= postUrl(post) %>"><div class="card-body"><span class="eyebrow"><%= post.category %></span><h3><%= post.title %></h3><p><%= post.excerpt %></p></div></a><% }) %></div></div></section>
<%- include('../partials/footer') %><%- include('../partials/quick-menu') %>
