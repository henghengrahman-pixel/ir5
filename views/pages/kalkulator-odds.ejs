<%- include('../partials/topbar') %>
<%- include('../partials/ticker') %>
<%- include('../partials/slider') %>
<%- include('../partials/auth-buttons') %>

<section class="calc-top">
  <div class="container">

    <div class="calc-top-box">
      <span class="calc-label">
        Kalkulator Odds
      </span>

      <h1>
        Kalkulator Parlay
      </h1>

      <p>
        Hitung kombinasi odds parlay dengan cepat dan mudah.
      </p>
    </div>

  </div>
</section>

<main class="container calc-wrapper">

  <div class="calc-left">

    <div class="calc-box">

      <div class="calc-head">
        <h2>Input Odds</h2>
      </div>

      <div class="calc-form">

        <label>
          Nominal Modal
        </label>

        <div class="calc-input-money">
          <span>Rp</span>

          <input
            id="stake"
            type="number"
            value="100000"
            min="1"
            step="1000"
            placeholder="100000"
          >
        </div>

        <div class="calc-title-row">
          <h3>Daftar Odds</h3>
        </div>

        <div id="legsContainer">

          <div class="calc-odds-row">

            <div class="calc-number">
              1
            </div>

            <input
              class="oddsInput"
              type="number"
              min="1"
              step="0.01"
              placeholder="1.85"
            >

            <button
              class="removeOdds"
              type="button"
            >
              ×
            </button>

          </div>

        </div>

        <div class="calc-buttons">

          <button
            id="addLeg"
            class="btn-gold"
            type="button"
          >
            Tambah Odds
          </button>

          <button
            id="calculateOdds"
            class="btn-green"
            type="button"
          >
            Hitung
          </button>

          <button
            id="resetOdds"
            class="btn-dark"
            type="button"
          >
            Reset
          </button>

        </div>

        <div id="calcNotice"></div>

      </div>

    </div>

  </div>

  <div class="calc-right">

    <div class="calc-box">

      <div class="calc-head">
        <h2>Hasil Perhitungan</h2>
      </div>

      <div class="calc-result">

        <div class="calc-result-item">
          <span>Total Odds</span>
          <strong id="totalOdds">1.00</strong>
        </div>

        <div class="calc-result-item">
          <span>Estimasi Menang</span>
          <strong id="payout">Rp 0</strong>
        </div>

        <div class="calc-result-item">
          <span>Profit</span>
          <strong id="profit">Rp 0</strong>
        </div>

      </div>

      <div class="calc-note">

        <h3>Cara Hitung</h3>

        <p>
          Semua odds akan dikalikan otomatis,
          lalu dikalikan dengan nominal modal.
        </p>

      </div>

    </div>

    <div class="calc-box calc-guide">

      <div class="calc-head">
        <h2>Cara Pakai</h2>
      </div>

      <ul>
        <li>Masukkan nominal modal taruhan.</li>
        <li>Isi seluruh odds pilihan.</li>
        <li>Klik tombol hitung.</li>
      </ul>

    </div>

  </div>

</main>

<script>
document.addEventListener('DOMContentLoaded', () => {

  const legsContainer = document.getElementById('legsContainer');
  const addLegBtn = document.getElementById('addLeg');
  const calculateBtn = document.getElementById('calculateOdds');
  const resetBtn = document.getElementById('resetOdds');

  const totalOddsEl = document.getElementById('totalOdds');
  const payoutEl = document.getElementById('payout');
  const profitEl = document.getElementById('profit');

  const stakeInput = document.getElementById('stake');
  const notice = document.getElementById('calcNotice');

  function rupiah(value) {
    return 'Rp ' + Number(value).toLocaleString('id-ID');
  }

  function refreshNumber() {

    document.querySelectorAll('.calc-odds-row').forEach((row, index) => {

      row.querySelector('.calc-number').textContent = index + 1;

    });

  }

  function showNotice(text, success = false) {

    notice.innerHTML = text;

    notice.style.display = 'block';

    notice.style.background = success
      ? 'rgba(0,180,90,.15)'
      : 'rgba(255,60,60,.15)';

    notice.style.color = success
      ? '#00d26a'
      : '#ff6666';

    setTimeout(() => {
      notice.style.display = 'none';
    }, 2500);

  }

  addLegBtn.addEventListener('click', () => {

    const row = document.createElement('div');

    row.className = 'calc-odds-row';

    row.innerHTML = `
      <div class="calc-number">1</div>

      <input
        class="oddsInput"
        type="number"
        min="1"
        step="0.01"
        placeholder="1.85"
      >

      <button
        class="removeOdds"
        type="button"
      >
        ×
      </button>
    `;

    legsContainer.appendChild(row);

    refreshNumber();

  });

  legsContainer.addEventListener('click', (e) => {

    if (!e.target.classList.contains('removeOdds')) return;

    if (document.querySelectorAll('.calc-odds-row').length <= 1) {

      showNotice('Minimal 1 odds.');

      return;

    }

    e.target.closest('.calc-odds-row').remove();

    refreshNumber();

  });

  calculateBtn.addEventListener('click', () => {

    const inputs = document.querySelectorAll('.oddsInput');

    let totalOdds = 1;
    let valid = true;

    inputs.forEach(input => {

      const value = parseFloat(input.value);

      if (isNaN(value) || value < 1) {

        valid = false;

        input.style.borderColor = '#ff4d4d';

      } else {

        input.style.borderColor = '';

        totalOdds *= value;

      }

    });

    if (!valid) {

      showNotice('Isi semua odds dengan benar.');

      return;

    }

    const stake = parseFloat(stakeInput.value);

    if (isNaN(stake) || stake <= 0) {

      showNotice('Nominal modal tidak valid.');

      return;

    }

    const payout = totalOdds * stake;
    const profit = payout - stake;

    totalOddsEl.textContent = totalOdds.toFixed(2);
    payoutEl.textContent = rupiah(payout);
    profitEl.textContent = rupiah(profit);

    showNotice('Perhitungan berhasil.', true);

  });

  resetBtn.addEventListener('click', () => {

    stakeInput.value = 100000;

    legsContainer.innerHTML = `
      <div class="calc-odds-row">

        <div class="calc-number">
          1
        </div>

        <input
          class="oddsInput"
          type="number"
          min="1"
          step="0.01"
          placeholder="1.85"
        >

        <button
          class="removeOdds"
          type="button"
        >
          ×
        </button>

      </div>
    `;

    totalOddsEl.textContent = '1.00';
    payoutEl.textContent = 'Rp 0';
    profitEl.textContent = 'Rp 0';

    showNotice('Berhasil direset.', true);

  });

});
</script>

<%- include('../partials/footer') %>
<%- include('../partials/quick-menu') %>
