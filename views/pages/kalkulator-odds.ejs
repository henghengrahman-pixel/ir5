<%- include('../partials/topbar') %>
<%- include('../partials/ticker') %>
<%- include('../partials/slider') %>
<%- include('../partials/auth-buttons') %>

<section class="calc-top">
  <div class="container">

    <div class="calc-top-box">

      <div class="calc-top-content">

        <span class="calc-label">
          Kalkulator Odds
        </span>

        <h1>
          Kalkulator Parlay
        </h1>

        <p>
          Hitung kombinasi odds parlay dengan cepat,
          simpel, dan nyaman digunakan.
        </p>

      </div>

    </div>

  </div>
</section>

<main class="container calc-wrapper">

  <div class="calc-left">

    <div class="calc-box">

      <div class="calc-head">
        <h2>Input Odds</h2>
      </div>

      <div class="calc-form">

        <label>
          Nominal Modal
        </label>

        <div class="calc-input-money">

          <span>Rp</span>

          <input
            id="stake"
            type="number"
            value="100000"
            min="1"
            step="1000"
            placeholder="100000"
          >

        </div>

        <div class="calc-title-row">
          <h3>Daftar Odds</h3>
        </div>

        <div id="legsContainer">

          <div class="calc-odds-row">

            <div class="calc-number">
              1
            </div>

            <input
              class="oddsInput"
              type="number"
              min="1"
              step="0.01"
              placeholder="1.85"
            >

            <button
              class="removeOdds"
              type="button"
            >
              ×
            </button>

          </div>

        </div>

        <div class="calc-buttons">

          <button
            id="addLeg"
            class="btn-gold"
            type="button"
          >
            Tambah Odds
          </button>

          <button
            id="calculateOdds"
            class="btn-green"
            type="button"
          >
            Hitung
          </button>

          <button
            id="resetOdds"
            class="btn-dark"
            type="button"
          >
            Reset
          </button>

        </div>

        <div id="calcNotice"></div>

      </div>

    </div>

  </div>

  <div class="calc-right">

    <div class="calc-box">

      <div class="calc-head">
        <h2>Hasil Perhitungan</h2>
      </div>

      <div class="calc-result">

        <div class="calc-result-item">
          <span>Total Odds</span>
          <strong id="totalOdds">1.00</strong>
        </div>

        <div class="calc-result-item">
          <span>Estimasi Menang</span>
          <strong id="payout">Rp 0</strong>
        </div>

        <div class="calc-result-item">
          <span>Profit</span>
          <strong id="profit">Rp 0</strong>
        </div>

      </div>

      <div class="calc-note">

        <h3>Cara Hitung</h3>

        <p>
          Semua odds akan dikalikan otomatis,
          lalu dihitung berdasarkan nominal modal.
        </p>

      </div>

    </div>

    <div class="calc-box calc-guide">

      <div class="calc-head">
        <h2>Cara Pakai</h2>
      </div>

      <ul>
        <li>Masukkan nominal modal taruhan.</li>
        <li>Isi seluruh odds pilihan.</li>
        <li>Klik tombol hitung.</li>
      </ul>

    </div>

  </div>

</main>

<script>
document.addEventListener('DOMContentLoaded', () => {

  const container = document.getElementById('legsContainer');

  const addBtn = document.getElementById('addLeg');
  const calcBtn = document.getElementById('calculateOdds');
  const resetBtn = document.getElementById('resetOdds');

  const totalOdds = document.getElementById('totalOdds');
  const payout = document.getElementById('payout');
  const profit = document.getElementById('profit');

  const stake = document.getElementById('stake');

  const notice = document.getElementById('calcNotice');

  function formatRp(number) {

    return 'Rp ' + Number(number).toLocaleString('id-ID');

  }

  function updateNumbers() {

    const rows = document.querySelectorAll('.calc-odds-row');

    rows.forEach((row, index) => {

      const no = row.querySelector('.calc-number');

      no.textContent = index + 1;

    });

  }

  function showNotice(text, success = false) {

    notice.style.display = 'block';

    notice.innerHTML = text;

    notice.style.color = success
      ? '#22c55e'
      : '#ef4444';

    clearTimeout(window.noticeTimer);

    window.noticeTimer = setTimeout(() => {

      notice.style.display = 'none';

    }, 2000);

  }

  function createRow() {

    const row = document.createElement('div');

    row.className = 'calc-odds-row';

    row.innerHTML = `
      <div class="calc-number">
        1
      </div>

      <input
        class="oddsInput"
        type="number"
        min="1"
        step="0.01"
        placeholder="1.85"
      >

      <button
        class="removeOdds"
        type="button"
      >
        ×
      </button>
    `;

    container.appendChild(row);

    updateNumbers();

  }

  addBtn.addEventListener('click', createRow);

  container.addEventListener('click', (e) => {

    if (!e.target.classList.contains('removeOdds')) return;

    const rows = document.querySelectorAll('.calc-odds-row');

    if (rows.length <= 1) {

      showNotice('Minimal 1 odds');

      return;

    }

    e.target.closest('.calc-odds-row').remove();

    updateNumbers();

  });

  calcBtn.addEventListener('click', () => {

    const inputs = document.querySelectorAll('.oddsInput');

    let oddsTotal = 1;

    let valid = true;

    inputs.forEach(input => {

      const value = parseFloat(input.value);

      if (isNaN(value) || value < 1) {

        valid = false;

        input.style.borderColor = '#ef4444';

      } else {

        input.style.borderColor = '';

        oddsTotal *= value;

      }

    });

    if (!valid) {

      showNotice('Isi odds dengan benar');

      return;

    }

    const modal = parseFloat(stake.value);

    if (isNaN(modal) || modal <= 0) {

      showNotice('Nominal modal tidak valid');

      return;

    }

    const hasil = oddsTotal * modal;

    const untung = hasil - modal;

    totalOdds.textContent = oddsTotal.toFixed(2);

    payout.textContent = formatRp(hasil);

    profit.textContent = formatRp(untung);

    showNotice('Perhitungan berhasil', true);

  });

  resetBtn.addEventListener('click', () => {

    container.innerHTML = `
      <div class="calc-odds-row">

        <div class="calc-number">
          1
        </div>

        <input
          class="oddsInput"
          type="number"
          min="1"
          step="0.01"
          placeholder="1.85"
        >

        <button
          class="removeOdds"
          type="button"
        >
          ×
        </button>

      </div>
    `;

    stake.value = 100000;

    totalOdds.textContent = '1.00';

    payout.textContent = 'Rp 0';

    profit.textContent = 'Rp 0';

    notice.style.display = 'none';

  });

  updateNumbers();

});
</script>

<%- include('../partials/footer') %>
<%- include('../partials/quick-menu') %>
