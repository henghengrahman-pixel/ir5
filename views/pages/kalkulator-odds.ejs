<%- include('partials/topbar') %>
<%- include('partials/ticker') %>
<%- include('partials/slider') %>
<%- include('partials/auth-buttons') %>

<section class="odds-page">
  <div class="container odds-container">

    <div class="odds-card">
      <div class="odds-header">
        <h1>Kalkulator Odds Parlay</h1>
        <p>Hitung total odds, estimasi hasil, dan profit taruhan.</p>
      </div>

      <div class="odds-form">
        <label>Nominal Taruhan</label>
        <input type="number" id="stake" value="100000">

        <div id="oddsInputs">
          <div class="odds-row">
            <input type="number" class="odds-input" step="0.01" placeholder="Contoh: 1.85">
          </div>
        </div>

        <div class="odds-buttons">
          <button onclick="addOdds()">+ Tambah Odds</button>
          <button onclick="calculateParlay()">Hitung</button>
          <button onclick="resetParlay()">Reset</button>
        </div>
      </div>

      <div class="result-box">
        <div class="result-item">
          <span>Total Odds</span>
          <strong id="totalOdds">1.00</strong>
        </div>

        <div class="result-item">
          <span>Estimasi Menang</span>
          <strong id="totalWin">Rp 0</strong>
        </div>

        <div class="result-item">
          <span>Profit</span>
          <strong id="profit">Rp 0</strong>
        </div>
      </div>

    </div>

  </div>
</section>

<script>
function addOdds() {
  const wrapper = document.getElementById('oddsInputs');

  wrapper.insertAdjacentHTML('beforeend', `
    <div class="odds-row">
      <input type="number" class="odds-input" step="0.01" placeholder="Contoh: 1.85">
    </div>
  `);
}

function calculateParlay() {
  const odds = document.querySelectorAll('.odds-input');
  const stake = parseFloat(document.getElementById('stake').value || 0);

  let total = 1;

  odds.forEach(input => {
    const val = parseFloat(input.value || 1);
    total *= val;
  });

  const totalWin = total * stake;
  const profit = totalWin - stake;

  document.getElementById('totalOdds').innerText = total.toFixed(2);
  document.getElementById('totalWin').innerText =
    'Rp ' + totalWin.toLocaleString('id-ID');

  document.getElementById('profit').innerText =
    'Rp ' + profit.toLocaleString('id-ID');
}

function resetParlay() {
  document.getElementById('stake').value = 100000;

  document.getElementById('oddsInputs').innerHTML = `
    <div class="odds-row">
      <input type="number" class="odds-input" step="0.01" placeholder="Contoh: 1.85">
    </div>
  `;

  document.getElementById('totalOdds').innerText = '1.00';
  document.getElementById('totalWin').innerText = 'Rp 0';
  document.getElementById('profit').innerText = 'Rp 0';
}
</script>

<%- include('partials/footer') %>
