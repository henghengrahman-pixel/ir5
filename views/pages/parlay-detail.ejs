<%- include('../partials/topbar') %>
<% const allMatches = (post.predictions || []).flatMap(function(l){ return (l.matches || []).map(function(m){ return Object.assign({}, m, {league:l.league}); }); }); %>
<% const featured = post.parlayStats.bestPick || allMatches[0] || {}; %>
<% const featuredTeams = String(featured.match || post.title || 'Home vs Away').split(' vs '); %>
<main class="detail-page">
  <section class="detail-hero">
    <div class="container">
      <nav class="breadcrumb"><a href="/">Home</a><span>/</span><a href="/prediksi-parlay">Prediksi Parlay</a><span>/</span><strong><%= post.title %></strong></nav>
      <div class="detail-hero-card">
        <div class="team-hero"><div class="team-logo"><%= (featuredTeams[0] || 'H').trim().slice(0,1) %></div><strong><%= featuredTeams[0] || 'Home' %></strong></div>
        <div class="match-center">
          <span class="match-status"><%= featured.status || 'PREVIEW' %></span>
          <h1><%= post.title %></h1>
          <p><%= featured.league || post.category || 'Prediksi Parlay' %> • <%= featured.time || fmtDate(post.createdAt) %></p>
          <div class="main-pick"><span>Prediction Pick</span><strong><%= featured.market || featured.pick || '-' %></strong></div>
        </div>
        <div class="team-hero"><div class="team-logo"><%= (featuredTeams[1] || 'A').trim().slice(0,1) %></div><strong><%= featuredTeams[1] || 'Away' %></strong></div>
      </div>
    </div>
  </section>
  <section class="container detail-layout">
    <article class="analysis-card">
      <div class="article-head"><span class="eyebrow">Match Analysis</span><h2>Analisa Prediksi</h2></div>
      <p class="lead"><%= post.excerpt || 'Pertandingan ini masuk dalam daftar pilihan karena form tim, tren gol, dan momentum pertandingan terlihat cukup menarik untuk diperhatikan.' %></p>
      <% if (post.content) { %><div class="article-content"><%- post.content %></div><% } %>
      <div class="confidence-box">
        <div><span>Confidence Meter</span><strong><%= post.parlayStats.avgConfidence || featured.confidence || 0 %>%</strong></div>
        <div class="confidence"><span style="width:<%= post.parlayStats.avgConfidence || featured.confidence || 0 %>%"></span></div>
        <p>Angka confidence adalah indikator kekuatan pilihan berdasarkan data yang tersedia, bukan jaminan hasil akhir.</p>
      </div>
      <div class="section-head compact"><div><span class="eyebrow">Prediction Board</span><h2>Daftar Pick</h2></div></div>
      <% (post.predictions || []).forEach(function(league){ %>
      <section class="league-block">
        <h3><%= league.league %></h3>
        <div class="match-card-grid-detail">
          <% (league.matches || []).forEach(function(match){ const teams = String(match.match || '').split(' vs '); %>
          <article class="premium-match-card">
            <div class="match-card-top"><span><%= league.league %></span><b><%= match.time %></b></div>
            <div class="teams-row">
              <div><div class="team-logo small"><%= (teams[0] || 'H').trim().slice(0,1) %></div><strong><%= teams[0] || 'Home' %></strong></div>
              <em>vs</em>
              <div><div class="team-logo small"><%= (teams[1] || 'A').trim().slice(0,1) %></div><strong><%= teams[1] || 'Away' %></strong></div>
            </div>
            <div class="pick-grid">
              <span><small>Pick</small><b><%= match.market || match.pick %></b></span>
              <span><small>Odds</small><b><%= match.odds %></b></span>
              <span><small>Status</small><b><%= match.status %></b></span>
              <span><small>Skor</small><b><%= match.score %></b></span>
            </div>
            <div class="form-row"><span>Form Home: <b><%= match.formHome %></b></span><span>Form Away: <b><%= match.formAway %></b></span></div>
            <div class="confidence"><span style="width:<%= match.confidence %>%"></span></div>
            <p><%= match.reason %></p>
          </article>
          <% }) %>
        </div>
      </section>
      <% }) %>
    </article>
    <aside class="detail-sidebar">
      <div class="side-card"><span class="eyebrow">Parlay Stats</span><div class="side-stat"><b><%= post.parlayStats.totalMatches %></b><span>Total Match</span></div><div class="side-stat"><b><%= post.parlayStats.safeCount %></b><span>Safe Pick</span></div><div class="side-stat"><b><%= post.parlayStats.totalOdds %></b><span>Odds Estimasi</span></div></div>
      <div class="side-card"><span class="eyebrow">H2H & Market</span><p>H2H utama: <b><%= featured.h2h || '-' %></b></p><p>Trend market: <b><%= featured.trend || '-' %></b></p><p>Risk level: <b><%= featured.risk || '-' %></b></p></div>
      <% if (related.length) { %><div class="side-card"><span class="eyebrow">Related Matches</span><% related.forEach(function(item){ %><a class="related-link" href="<%= parlayUrl(item) %>"><%= item.title %><small><%= fmtDate(item.createdAt) %></small></a><% }) %></div><% } %>
    </aside>
  </section>
</main>
<script type="application/ld+json"><%- JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":post.title,"description":post.excerpt || pageDescription,"datePublished":post.createdAt || new Date().toISOString(),"mainEntityOfPage":canonical || ''}) %></script>
<%- include('../partials/footer') %>
