<%- include('../partials/topbar') %><%- include('../partials/ticker') %>
<main class="container section content-layout"><article class="article-detail"><a class="eyebrow" href="/prediksi-parlay">Prediksi Bola</a><h1><%= post.title %></h1><div class="meta"><span>By <%= post.author || 'Analis Bola' %></span><span><%= fmtDate(post.createdAt) %></span><% (post.tags||[]).forEach(function(tag){ %><span>#<%= tag %></span><% }) %></div><% if(post.cover || post.thumbnail){ %><img class="article-cover" src="<%= post.cover || post.thumbnail %>" alt="<%= post.title %>"><% } %><div class="article-content"><%- post.content %></div><section class="section"><h2>Detail Prediksi Match</h2><div class="prediction-list"><% (post.predictions||[]).forEach(function(group){ (group.matches||[]).forEach(function(m){ const teams=String(m.match||'').split(/\s+vs\s+|\s+-\s+/i); const home=m.homeName||teams[0]||'Home'; const away=m.awayName||teams[1]||'Away'; const conf=Number(m.confidence||70); %><div class="match-card"><div class="match-top"><span><%= group.league %></span><span><%= m.kickoffWib || m.time || '-' %></span></div><div class="teams"><div class="team"><% if(m.homeLogo){ %><img class="team-logo" src="<%= m.homeLogo %>" onerror="this.src='/assets/img/default-team.png'"><% } else { %><span class="team-logo"></span><% } %><b><%= home %></b></div><div class="vs">VS</div><div class="team away"><b><%= away %></b><% if(m.awayLogo){ %><img class="team-logo" src="<%= m.awayLogo %>" onerror="this.src='/assets/img/default-team.png'"><% } else { %><span class="team-logo"></span><% } %></div></div><div class="pick-row"><div class="pill"><small>Prediksi</small><b><%= m.prediction || m.pick || '-' %></b></div><div class="pill"><small>Skor</small><b><%= m.predictedScore || m.score || '-' %></b></div><div class="pill"><small>O/U</small><b><%= m.overUnder || m.ou || '-' %></b></div><div class="pill"><small>Confidence</small><b><%= conf %>%</b><div class="progress"><i style="width:<%= conf %>%"></i></div></div></div></div><% }) }) %></div></section></article><aside class="sidebar"><div class="soft-card"><h3>Prediksi Terkait</h3><% (related||[]).forEach(function(item){ %><p><a href="<%= parlayUrl(item) %>"><b><%= item.title %></b></a><br><small><%= fmtDate(item.createdAt) %></small></p><% }) %></div><% (ads||[]).forEach(function(ad){ %><a class="soft-card" href="<%= ad.link||'#' %>"><% if(ad.image){ %><img src="<%= ad.image %>" alt="<%= ad.title %>"><% } %><b><%= ad.title %></b></a><% }) %></aside></main>
<%- include('../partials/footer') %><%- include('../partials/quick-menu') %>
