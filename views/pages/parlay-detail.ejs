<%- include('../partials/topbar') %>
<%- include('../partials/ticker') %>
<%- include('../partials/slider') %>
<%- include('../partials/auth-buttons') %>

<main class="container parlay-layout parlay-single-layout">

  <article class="parlay-single parlay-single-pro">

    <div class="single-hero">

      <div class="single-top">

        <a
          class="badge"
          href="/category/<%= String(post.category || '').toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'') %>"
        >
          <%= post.category || 'Prediksi Parlay' %>
        </a>

        <% 
          const totalMatches =
            Array.isArray(post.predictions)
              ? post.predictions.reduce((a,b)=>a+(b.matches?.length||0),0)
              : 0;
        %>

        <% if (totalMatches) { %>

          <span class="match-count">
            <%= totalMatches %> Match
          </span>

        <% } %>

      </div>

      <h1>
        <%= post.title %>
      </h1>

      <div class="single-meta">

        <span>
          <i class="fa-regular fa-user"></i>
          <strong>
            <%= post.author || 'Master Parlay' %>
          </strong>
        </span>

        <span>
          <i class="fa-regular fa-calendar"></i>
          <%= fmtDate(post.createdAt) %>
        </span>

        <% (post.tags || []).forEach(function(tag){ %>

          <span class="tag">
            #<%= tag %>
          </span>

        <% }) %>

      </div>

      <% if (post.thumbnail) { %>

        <div class="single-cover-wrap">

          <img
            class="single-cover"
            src="<%= post.thumbnail %>"
            alt="<%= post.title %>"
            loading="lazy"
            onerror="this.style.display='none'"
          >

        </div>

      <% } %>

    </div>

    <div class="article-content">
      <%- post.content %>
    </div>

    <% if (
      Array.isArray(post.predictions) &&
      post.predictions.length
    ) { %>

      <section class="prediction-board">

        <div class="section-title">

          <span>
            BIG MATCH
          </span>

          <h2>
            Prediksi Parlay Malam Ini
          </h2>

        </div>

        <% post.predictions.forEach(function(league){ %>

          <section class="league-section">

            <div class="league-header">

              <h3 class="league-title">
                <%= league.league %>
              </h3>

              <span class="league-total">
                <%= (league.matches || []).length %> Match
              </span>

            </div>

            <div class="matches-wrap">

              <% (league.matches || []).forEach(function(match){ %>

                <article class="match-card">

                  <div class="match-top">

                    <div class="match-time">

                      <span>
                        <%= match.kickoffWib || '-' %>
                      </span>

                    </div>

                    <% if (match.confidence) { %>

                      <div class="confidence">

                        <div class="confidence-bar">

                          <span
                            style="width:<%= match.confidence %>%"
                          ></span>

                        </div>

                        <strong>
                          <%= match.confidence %>%
                        </strong>

                      </div>

                    <% } %>

                  </div>

                  <div class="match-center">

                    <div class="team-side">

                      <% if (match.homeLogo) { %>

                        <img
                          src="<%= match.homeLogo %>"
                          alt="<%= match.homeName %>"
                          loading="lazy"
                          onerror="this.style.display='none'"
                        >

                      <% } %>

                      <strong>
                        <%= match.homeName %>
                      </strong>

                    </div>

                    <div class="match-middle">

                      <span class="vs">
                        VS
                      </span>

                      <div class="predict-score">
                        <%= match.predictedScore || match.score || '-' %>
                      </div>

                    </div>

                    <div class="team-side">

                      <% if (match.awayLogo) { %>

                        <img
                          src="<%= match.awayLogo %>"
                          alt="<%= match.awayName %>"
                          loading="lazy"
                          onerror="this.style.display='none'"
                        >

                      <% } %>

                      <strong>
                        <%= match.awayName %>
                      </strong>

                    </div>

                  </div>

                  <div class="match-bottom">

                    <div class="pick-box">

                      <span>
                        1X2
                      </span>

                      <strong>
                        <%= match.pick || '-' %>
                      </strong>

                    </div>

                    <div class="pick-box">

                      <span>
                        O/U
                      </span>

                      <strong>
                        <%= match.ou || '-' %>
                      </strong>

                    </div>

                    <div class="pick-box">

                      <span>
                        Prediksi
                      </span>

                      <strong>
                        <%= match.prediction || match.tip || '-' %>
                      </strong>

                    </div>

                  </div>

                  <% if (
                    match.form ||
                    match.stats ||
                    match.h2h
                  ) { %>

                    <div class="extra-info">

                      <% if (match.form) { %>

                        <div class="extra-box">

                          <span>
                            Form
                          </span>

                          <p>
                            <%= typeof match.form === 'string'
                              ? match.form
                              : JSON.stringify(match.form)
                            %>
                          </p>

                        </div>

                      <% } %>

                      <% if (match.h2h) { %>

                        <div class="extra-box">

                          <span>
                            H2H
                          </span>

                          <p>
                            Data head to head tersedia
                          </p>

                        </div>

                      <% } %>

                    </div>

                  <% } %>

                </article>

              <% }) %>

            </div>

          </section>

        <% }) %>

      </section>

    <% } %>

    <section class="parlay-note">

      <div class="note-box">

        <h3>
          Rekomendasi Bermain Aman
        </h3>

        <p>
          Gunakan prediksi ini sebagai referensi tambahan sebelum menentukan pilihan taruhan. Selalu bermain dengan pengelolaan risiko yang baik dan gunakan nominal yang sesuai.
        </p>

      </div>

    </section>

    <% if (related.length) { %>

      <section class="related">

        <div class="section-title">

          <span>
            UPDATE LAINNYA
          </span>

          <h3>
            Prediksi Terkait
          </h3>

        </div>

        <div class="related-grid">

          <% related.forEach(function(item){ %>

            <a
              class="related-card"
              href="<%= parlayUrl(item) %>"
            >

              <% if (item.thumbnail) { %>

                <img
                  src="<%= item.thumbnail %>"
                  alt="<%= item.title %>"
                  loading="lazy"
                  onerror="this.style.display='none'"
                >

              <% } %>

              <div class="related-body">

                <span>
                  <%= fmtDate(item.createdAt) %>
                </span>

                <strong>
                  <%= item.title %>
                </strong>

              </div>

            </a>

          <% }) %>

        </div>

      </section>

    <% } %>

  </article>

  <%- include('../partials/sidebar-blog', {
    latestPosts,
    ads
  }) %>

</main>

<%- include('../partials/footer') %>
<%- include('../partials/quick-menu') %>
