<%- include('../partials/topbar') %><%- include('../partials/ticker') %>
<main class="container section content-layout"><article class="article-detail"><a class="eyebrow" href="/category/<%= categorySlug(post.category) %>"><%= post.category %></a><h1><%= post.title %></h1><div class="meta"><span>By <%= post.author || 'Redaksi' %></span><span><%= fmtDate(post.createdAt) %></span><% (post.tags||[]).forEach(function(tag){ %><span>#<%= tag %></span><% }) %></div><% if(post.cover || post.thumbnail){ %><img class="article-cover" src="<%= post.cover || post.thumbnail %>" alt="<%= post.title %>"><% } %><div class="article-content"><%- post.content %></div></article><aside class="sidebar"><div class="soft-card"><h3>Related Article</h3><% (related||[]).forEach(function(item){ %><p><a href="<%= postUrl(item) %>"><b><%= item.title %></b></a><br><small><%= fmtDate(item.createdAt) %></small></p><% }) %></div></aside></main>
<%- include('../partials/footer') %><%- include('../partials/quick-menu') %>
