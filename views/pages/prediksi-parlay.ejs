<%- include('../partials/topbar') %><%- include('../partials/ticker') %>
<section class="page-title"><div class="container"><span class="eyebrow">Prediksi Bola Premium</span><h1>Prediksi Bola Hari Ini</h1><p>Data fokus pada Liga Indonesia, Premier League, Champions League, Serie A, La Liga, Bundesliga, Ligue 1, Europa League, dan liga terkenal lainnya. Liga random kecil tidak diprioritaskan.</p></div></section>
<section class="section"><div class="container"><div class="prediction-list"><% if((homePredictions||[]).length){ homePredictions.forEach(function(m){ %><a class="match-card" href="<%= m.url %>"><div class="match-top"><span><%= m.league %></span><span><%= m.kickoffWib %></span></div><div class="teams"><div class="team"><% if(m.homeLogo){ %><img class="team-logo" src="<%= m.homeLogo %>" onerror="this.src='/assets/img/default-team.png'"><% } else { %><span class="team-logo"></span><% } %><b><%= m.homeName %></b></div><div class="vs">VS</div><div class="team away"><b><%= m.awayName %></b><% if(m.awayLogo){ %><img class="team-logo" src="<%= m.awayLogo %>" onerror="this.src='/assets/img/default-team.png'"><% } else { %><span class="team-logo"></span><% } %></div></div><div class="pick-row"><div class="pill"><small>1X2</small><b><%= m.prediction %></b></div><div class="pill"><small>Skor</small><b><%= m.predictedScore %></b></div><div class="pill"><small>Over/Under</small><b><%= m.overUnder %></b></div><div class="pill"><small>Confidence</small><b><%= m.confidence %>%</b><div class="progress"><i style="width:<%= m.confidence %>%"></i></div></div></div></a><% }) } else { %><div class="empty">Belum ada prediksi. Tambah artikel prediksi dari admin atau jalankan auto parlay.</div><% } %></div></div></section>
<section class="section"><div class="container"><div class="section-head"><h2>Artikel Prediksi</h2></div><div class="cards-grid"><% posts.forEach(function(post){ %><a class="article-card" href="<%= parlayUrl(post) %>"><div class="thumb"><% if(post.thumbnail){ %><img src="<%= post.thumbnail %>" alt="<%= post.title %>"><% } else { %>PREDIKSI<% } %></div><div class="card-body"><div class="meta"><span><%= post.category %></span><span><%= fmtDate(post.createdAt) %></span></div><h3><%= post.title %></h3><p><%= post.excerpt %></p></div></a><% }) %></div></div></section>
<%- include('../partials/footer') %><%- include('../partials/quick-menu') %>
