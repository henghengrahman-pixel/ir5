<%- include('../partials/topbar') %>
<%- include('../partials/ticker') %>
<%- include('../partials/slider') %>
<%- include('../partials/auth-buttons') %>

<section class="parlay-hero">

  <div class="container">

    <div class="parlay-hero-wrap">

      <div class="parlay-hero-content">

        <span class="hero-badge">
          PREDIKSI PARLAY HARI INI
        </span>

        <h1>
          Prediksi Parlay
        </h1>

        <p>
          Update prediksi pertandingan pilihan dari liga besar dunia dan Liga Indonesia lengkap dengan prediksi skor, over under, dan pilihan terbaik malam ini.
        </p>

        <div class="hero-info">

          <span>
            <strong><%= posts.length %></strong> Artikel
          </span>

          <span class="dot"></span>

          <span>
            Update Harian
          </span>

        </div>

      </div>

    </div>

  </div>

</section>

<main class="container parlay-layout">

  <section class="parlay-list">

    <% if (!posts.length) { %>

      <article class="parlay-empty">

        <div class="empty-icon">
          ⚽
        </div>

        <h3>
          Belum Ada Prediksi
        </h3>

        <p>
          Prediksi pertandingan belum tersedia saat ini.
        </p>

      </article>

    <% } %>

    <% posts.forEach(function(post){ %>

      <% 
        const totalMatches =
          Array.isArray(post.predictions)
            ? post.predictions.reduce((a,b)=>a+(b.matches?.length||0),0)
            : 0;
      %>

      <article class="parlay-card">

        <a
          class="parlay-thumb"
          href="<%= parlayUrl(post) %>"
        >

          <img
            src="<%= post.thumbnail || '/assets/img/default.jpg' %>"
            alt="<%= post.title %>"
            loading="lazy"
            onerror="this.src='/assets/img/default.jpg'"
          >

          <div class="thumb-overlay">

            <span>
              BIG MATCH
            </span>

          </div>

        </a>

        <div class="parlay-body">

          <div class="parlay-top">

            <a
              class="badge"
              href="/category/<%= String(post.category || '').toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'') %>"
            >
              <%= post.category || 'Prediksi Parlay' %>
            </a>

            <% if (totalMatches) { %>

              <span class="match-total">
                <%= totalMatches %> Match
              </span>

            <% } %>

          </div>

          <h2>

            <a href="<%= parlayUrl(post) %>">
              <%= post.title %>
            </a>

          </h2>

          <div class="post-meta">

            <span>
              <i class="fa-regular fa-calendar"></i>
              <%= fmtDate(post.createdAt) %>
            </span>

            <span>
              <i class="fa-regular fa-user"></i>
              <%= post.author || 'Master Parlay' %>
            </span>

          </div>

          <p>
            <%= post.excerpt || 'Prediksi pertandingan pilihan lengkap dengan analisa pertandingan, prediksi skor, dan pilihan terbaik malam ini.' %>
          </p>

          <% if (
            Array.isArray(post.predictions) &&
            post.predictions.length
          ) { %>

            <div class="preview-matches">

              <% post.predictions.slice(0,2).forEach(function(group){ %>

                <% (group.matches || []).slice(0,2).forEach(function(match){ %>

                  <div class="preview-match">

                    <div class="teams">

                      <div class="team">

                        <% if (match.homeLogo) { %>

                          <img
                            src="<%= match.homeLogo %>"
                            alt="<%= match.homeName %>"
                            loading="lazy"
                            onerror="this.style.display='none'"
                          >

                        <% } %>

                        <span>
                          <%= match.homeName %>
                        </span>

                      </div>

                      <div class="vs">
                        VS
                      </div>

                      <div class="team">

                        <% if (match.awayLogo) { %>

                          <img
                            src="<%= match.awayLogo %>"
                            alt="<%= match.awayName %>"
                            loading="lazy"
                            onerror="this.style.display='none'"
                          >

                        <% } %>

                        <span>
                          <%= match.awayName %>
                        </span>

                      </div>

                    </div>

                    <div class="match-prediction">

                      <span class="pick">
                        <%= match.predictedScore || match.score || '-' %>
                      </span>

                      <small>
                        <%= match.prediction || match.tip || '' %>
                      </small>

                    </div>

                  </div>

                <% }) %>

              <% }) %>

            </div>

          <% } %>

          <div class="parlay-bottom">

            <a
              class="read-more"
              href="<%= parlayUrl(post) %>"
            >
              Baca Prediksi
            </a>

          </div>

        </div>

      </article>

    <% }) %>

    <% if (totalPages > 1) { %>

      <div class="pagination">

        <% if (currentPage > 1) { %>

          <a href="/prediksi-parlay?page=<%= currentPage - 1 %>">
            ‹
          </a>

        <% } %>

        <% for(let i = 1; i <= totalPages; i++){ %>

          <% if (
            i === currentPage ||
            i <= 2 ||
            i === totalPages ||
            Math.abs(i-currentPage) <= 1
          ) { %>

            <a
              class="<%= i === currentPage ? 'on' : '' %>"
              href="/prediksi-parlay?page=<%= i %>"
            >
              <%= i %>
            </a>

          <% } else if (
            i === 3 &&
            currentPage > 4
          ) { %>

            <span>
              ...
            </span>

          <% } %>

        <% } %>

        <% if (currentPage < totalPages) { %>

          <a href="/prediksi-parlay?page=<%= currentPage + 1 %>">
            ›
          </a>

        <% } %>

      </div>

    <% } %>

  </section>

  <%- include('../partials/sidebar-blog', {
    latestPosts: allPosts.slice(0, 8),
    ads
  }) %>

</main>

<%- include('../partials/footer') %>
<%- include('../partials/quick-menu') %>
