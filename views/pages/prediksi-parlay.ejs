
<%- include('../partials/head') %>
<link rel="stylesheet" href="/assets/css/parlay-modern.css">

<section class="page-wrap">
<div class="container">
<div class="hero-match">
<div>
<span class="eyebrow">SPORTS ANALYSIS PORTAL</span>
<h1>Prediksi Bola Hari Ini</h1>
<p>Analisa pertandingan pilihan dengan statistik pertandingan, performa tim, dan market odds terbaru.</p>
</div>
</div>

<div class="match-grid">
<%
const { normalizeMatch } = require('../../helpers/normalize-match');
const matches = posts.flatMap(p => (p.predictions||[]).flatMap(g => (g.matches||[]).map(m=>({raw:m,slug:p.slug}))));
matches.forEach(({raw,slug})=>{
const m = normalizeMatch(raw);
%>
<div class="modern-card">
<div class="topline">
<div class="league">
<% if(m.leagueLogo){ %><img src="<%= m.leagueLogo %>" class="league-logo"><% } %>
<span><%= m.leagueName %></span>
</div>
<div><%= m.kickoffWib %> WIB</div>
</div>

<div class="teams">
<div class="team">
<img src="<%= m.homeLogo || '/assets/img/team-placeholder.png' %>" onerror="this.src='/assets/img/team-placeholder.png'">
<h3><%= m.homeName %></h3>
</div>

<div class="versus">VS</div>

<div class="team">
<img src="<%= m.awayLogo || '/assets/img/team-placeholder.png' %>" onerror="this.src='/assets/img/team-placeholder.png'">
<h3><%= m.awayName %></h3>
</div>
</div>

<div class="pick-row">
<div>
<label>Prediction</label>
<strong><%= m.prediction %></strong>
</div>
<div>
<label>Odds</label>
<strong><%= m.odds %></strong>
</div>
</div>

<div class="confidence">
<div class="conf-head">
<span>Confidence</span>
<strong><%= m.confidence %>%</strong>
</div>
<div class="bar"><span style="width:<%= m.confidence %>%"></span></div>
</div>

<a href="/prediksi-parlay/<%= slug %>" class="detail-btn">Detail Analisa</a>
</div>
<% }) %>
</div>
</div>
</section>
