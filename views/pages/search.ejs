<%- include('../partials/topbar') %>
<%- include('../partials/ticker') %>
<%- include('../partials/slider') %>
<%- include('../partials/auth-buttons') %>

<main class="container blog-wrap search-results">

  <!-- ===================================================== -->
  <!-- HEAD -->
  <!-- ===================================================== -->

  <div class="latest-ribbon">
    <span>
      <%= q || 'Hasil Pencarian' %>
    </span>
  </div>

  <div class="search-head">

    <div>

      <h1>
        <%= q || 'Pencarian Berita Bola' %>
      </h1>

      <p>
        <% if(posts.length){ %>

          Menampilkan
          <strong><%= posts.length %></strong>
          artikel berita bola terbaru.

        <% } else { %>

          Tidak ditemukan artikel yang cocok dengan pencarian.

        <% } %>
      </p>

    </div>

    <form
      class="search-page-form"
      action="/search"
      method="get"
    >

      <input
        type="text"
        name="q"
        value="<%= q && !q.startsWith('Kategori:') ? q : '' %>"
        placeholder="Cari klub, pemain, transfer..."
      >

      <button type="submit">
        Cari
      </button>

    </form>

  </div>

  <!-- ===================================================== -->
  <!-- CONTENT -->
  <!-- ===================================================== -->

  <section class="post-list">

    <% if (!posts.length) { %>

      <article class="news-empty">

        <h3>
          Tidak ada hasil
        </h3>

        <p>
          Coba gunakan kata kunci lain untuk mencari berita bola.
        </p>

      </article>

    <% } %>

    <% posts.forEach(function(post){ %>

      <article class="news-card">

        <a
          class="news-thumb"
          href="<%= articleUrl ? articleUrl(post) : parlayUrl(post) %>"
        >

          <img
            src="<%= post.thumbnail || post.cover || settings.logoUrl || '/assets/img/default.jpg' %>"
            alt="<%= post.title %>"
            loading="lazy"

            onerror="
              this.onerror=null;
              this.src='<%= settings.logoUrl || '/assets/img/default.jpg' %>';
            "
          >

        </a>

        <div class="news-body">

          <!-- TOP -->

          <div class="news-top-meta">

            <a
              class="badge"
              href="/category/<%= categorySlug ? categorySlug(post.category) : String(post.category || '').toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'') %>"
            >
              <%= post.category || 'Berita Bola' %>
            </a>

            <% if(post.trending){ %>
              <span class="mini-hot">
                Trending
              </span>
            <% } %>

          </div>

          <!-- TITLE -->

          <h2>

            <a href="<%= articleUrl ? articleUrl(post) : parlayUrl(post) %>">

              <%= post.title %>

            </a>

          </h2>

          <!-- META -->

          <div class="post-meta">

            <span>
              <%= fmtDate(post.createdAt) %>
            </span>

            <span>•</span>

            <span>
              <%= post.author || 'Redaksi Bola' %>
            </span>

            <% if(post.tags?.length){ %>

              <span>•</span>

              <span>
                #<%= post.tags[0] %>
              </span>

            <% } %>

          </div>

          <!-- EXCERPT -->

          <p>

            <%= post.excerpt || 'Baca update lengkap berita bola terbaru, transfer pemain, hasil pertandingan, dan informasi sepak bola pilihan hari ini.' %>

          </p>

          <!-- ACTION -->

          <div class="news-actions">

            <a
              class="read-more"
              href="<%= articleUrl ? articleUrl(post) : parlayUrl(post) %>"
            >
              Baca Selengkapnya
            </a>

          </div>

        </div>

      </article>

    <% }) %>

  </section>

</main>

<%- include('../partials/footer') %>
<%- include('../partials/quick-menu') %>
