<script>window.__APP_CONFIG__ = { activePage: <%- JSON.stringify(activePage || "") %>, settings: <%- JSON.stringify(settings || {}) %> };</script>
<% (scripts || []).forEach(function(src) { %><script src="<%= src %>"></script>
<% }) %>

<script>
(function globalSearchInput(){
  const q = document.getElementById('q');
  if (!q) return;
  q.addEventListener('keydown', function(e){
    if (e.key !== 'Enter') return;
    const value = q.value.trim();
    if (value) window.location.href = '/search?q=' + encodeURIComponent(value);
  });
})();
</script>
