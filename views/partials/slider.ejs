<% if ((slides || []).length) { %><section class="section"><div class="container cards-grid"><% slides.slice(0,3).forEach(function(slide){ %><a class="article-card" href="<%= slide.link || '#' %>"><div class="thumb"><% if(slide.image){ %><img src="<%= slide.image %>" alt="<%= slide.title %>"><% } else { %>Big Match<% } %></div><div class="card-body"><span class="eyebrow">Highlight</span><h3><%= slide.title %></h3></div></a><% }) %></div></section><% } %>
